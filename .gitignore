# Visual Studio user specific files
AGD/.vs/
AGD/.vsconfig

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
AGD/*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
AGD/Binaries/
AGD/Plugins/**/Binaries/

# Builds
AGD/Build/

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!AGD/Build/*/
AGD/Build/*/**
!AGD/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!AGD/Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
AGD/Saved/

# Compiled source files for the engine to use
AGD/Intermediate/
AGD/Plugins/**/Intermediate/

# Cache files for the editor to use
AGD/DerivedDataCache/

# Extra generated files
AGD/Backup/
AGD/UpgradeLog.htm

# Your specific content exclusions
AGD/Content/LevelPrototyping/
AGD/Content/__ExternalActors__/
AGD/Content/__ExternalObjects__/
AGD/Content/Characters/
AGD/Content/ThirdPerson/Lvl_ThirdPerson.umap
AGD/Content/ThirdPerson/MI_ThirdPersonColWay.uasset
AGD/Content/Collections/
AGD/Content/Developers/
AGD/Content/Input/